# ════════════════════════════════════════════════════
# DEALPILOT BACKEND – Environment Configuration
# ════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# DO NOT commit .env to git

# ── Server ─────────────────────────────────────────
NODE_ENV=development
PORT=3001
# CORS: Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:8080,http://localhost:5500,http://127.0.0.1:5500

# Frontend base URL (for Stripe redirects, email links)
FRONTEND_BASE_URL=http://localhost:8080

# ── Database (PostgreSQL) ──────────────────────────
DATABASE_URL=postgresql://dealpilot:dealpilot_dev_pwd@localhost:5432/dealpilot_db

# ── Authentication ─────────────────────────────────
# IMPORTANT: Change this in production! Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_use_64_char_random_hex
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=11

# ── Rate Limiting ──────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# ── Admin Bootstrap (only used on first migration) ──
ADMIN_EMAIL=admin@dealpilot.local
ADMIN_PASSWORD=
ADMIN_NAME=Administrator

# ────────────────────────────────────────────────────
# UPLOADS / FILE STORAGE
# ────────────────────────────────────────────────────
# Local path on server. In production use absolute path on a persistent volume.
UPLOAD_DIR=./uploads
# Max single upload size (bytes). 5 MB default.
UPLOAD_MAX_BYTES=5242880

# ────────────────────────────────────────────────────
# OPENAI (server-side proxy for KI-Analyse)
# ────────────────────────────────────────────────────
# If set, the server will proxy KI requests so the API key never touches the client.
# Leave empty to keep the current client-side mode (key from Settings).
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# ────────────────────────────────────────────────────
# STRIPE (paid subscriptions)
# ────────────────────────────────────────────────────
# Test keys (sk_test_...) for development. Leave empty to disable paid plans.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ────────────────────────────────────────────────────
# EMAIL (verification, password reset)
# ────────────────────────────────────────────────────
# EMAIL_PROVIDER=resend         # 'resend' | 'sendgrid' | 'smtp'
# EMAIL_FROM=noreply@dealpilot.app
# EMAIL_API_KEY=

# ────────────────────────────────────────────────────
# PDF GENERATION (server-side – future)
# ────────────────────────────────────────────────────
# When set, server-side rendering uses headless Chrome.
# PDF_RENDERER=puppeteer
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# ─── V37: Beta-Signup SMTP (optional, falls leer → 503 in production) ───
# Beispiele:
#   Strato:  smtp.strato.de · 587 (STARTTLS)
#   IONOS:   smtp.ionos.de  · 587
#   Gmail:   smtp.gmail.com · 587 (App-Password nötig)
#   Eigener Server:  mail.junker-immobilien.io · 587 oder 465
BETA_SMTP_HOST=
BETA_SMTP_PORT=587
BETA_SMTP_SECURE=false
BETA_SMTP_USER=
BETA_SMTP_PASS=
BETA_MAIL_FROM=DealPilot <noreply@junker-immobilien.io>
# V63.77: Beta-Anfragen gehen an dealpilot@junker-immobilien.io
BETA_MAIL_TO=dealpilot@junker-immobilien.io

# ─────────────────────────────────────────────────────────────
# V63.77: ZENTRALE EMAIL-ROUTING-KONFIG
# ─────────────────────────────────────────────────────────────
# Alle Anfragen über Deal-Aktion (Bank, FB, Gutachten, Beratung, RND)
# gehen an DEAL_ACTION_FALLBACK (Default: dealpilot@…).
# Whitelist optional — leer lassen wenn alle Adressen erlaubt sein sollen.
DEAL_ACTION_ALLOWED_RECIPIENTS=
DEAL_ACTION_FALLBACK=dealpilot@junker-immobilien.io

# Feedback (Sterne-Bewertung) → dealpilot@…
FEEDBACK_MAIL_TO=dealpilot@junker-immobilien.io

# Support-Anfragen (Bug, Bedienungsfrage, etc.) → support@…
SUPPORT_MAIL_TO=support@junker-immobilien.io

# V63.77: Bestätigungs-E-Mails an Absender (true / false)
# Wenn aktiv, bekommt der Absender (replyTo der Anfrage) eine kurze
# "Wir haben deine Anfrage erhalten"-Mail.
SEND_CONFIRMATION_EMAILS=true

# ─────────────────────────────────────────────────────────────
# V63.78: NEXTCLOUD (Bank-Datenraum)
# ─────────────────────────────────────────────────────────────
# Bei Bankanfrage / Finanzierungsbestätigung werden hochgeladene
# Dokumente in einen frischen Ordner in Nextcloud abgelegt und ein
# zeitlich begrenzter Public-Share-Link in die Mail an den Empfänger
# eingebaut. Wenn diese Variablen LEER sind, fällt das System auf
# direkten Mail-Anhang zurück (wie V63.77).
NEXTCLOUD_BASE_URL=
NEXTCLOUD_USERNAME=
NEXTCLOUD_APP_PASSWORD=
NEXTCLOUD_BASE_FOLDER=DealPilot/Bankanfragen
NEXTCLOUD_SHARE_EXPIRES_DAYS=30

# ─────────────────────────────────────────────────────────────
# V63.80: 2FA (TOTP)
# ─────────────────────────────────────────────────────────────
# Issuer-Name in der Authenticator-App (Standard: DealPilot)
TOTP_ISSUER=DealPilot
