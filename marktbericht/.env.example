# --- Marktbericht-Service ENV ---
# Kopiere zu .env und trage deine Keys ein.

# Geoapify (Geocoding + POI/Mikrolage). Ohne Key: Geocoding/POI liefern leer.
GEOAPIFY_KEY=

# KI-Report: stub = Template ohne API. openai = echter Bericht.
REPORT_AI_MODE=stub
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# Marktdaten-Quelle: seed (generierte Vergleichsobjekte) | csv_import
MARKET_SOURCE=seed

# DB (für lokalen Lauf OHNE Docker; mit Docker werden diese überschrieben)
PGHOST=localhost
PGPORT=5433
PGUSER=mb
PGPASSWORD=mb
PGDATABASE=marktbericht
PORT=4000

# Seed-Menge pro Stadt/Typ
SEED_N=60

# GeoMap (echte Vergleichsangebote DE/AT/CH) — Token aus deinem GeoMap-Account
GEOMAP_TOKEN=
GEOMAP_BASE=https://api.geomap.immo
GEOMAP_MAX_DETAILS=40
GEOMAP_RADIUS_KM=5
# Einzelobjekte pro Report fuer Karte/Tabelle (je 1 Abruf = Kosten). 0 = nur guenstige KPI-Statistik.
GEOMAP_REPORT_LISTINGS=0

# BORIS-NRW Bodenrichtwerte (Open Data, dl-de/zero-2-0). Kein Key noetig.
# Nur NRW-Abdeckung. Defaults sind gesetzt - nur aendern, wenn der Dienst umzieht.
BORIS_NRW_WMS=https://www.wms.nrw.de/boris/wms-t_nw_brw
BORIS_NRW_LAYER=brw_sonstige_flaechen

# GeoMap Wertentwicklung (Historie): Startjahr + ob Miethistorie zusaetzlich geholt wird
GEOMAP_HISTORY_START=2018
GEOMAP_HISTORY_RENT=false

# Destatis / Regionalstatistik (Sozioökonomie) - kostenloser Token nach Registrierung
# bei regionalstatistik.de eintragen. Ohne Token bleibt Sozioökonomie "nicht angebunden".
DESTATIS_TOKEN=
DESTATIS_PASSWORD=
DESTATIS_BASE=https://www.regionalstatistik.de/genesisws/rest/2020
# WICHTIG: regionalstatistik.de hat EIGENE Tabellencodes (Format NNNNN-NN-NN-N),
# NICHT die Destatis-Bundescodes (z.B. 12411-0014 funktioniert hier NICHT).
DESTATIS_TABLE_POP=12411-01-01-4
DESTATIS_TABLE_INCOME=82411-01-03-4
DESTATIS_TABLE_UNEMP=13211-02-05-4

# Zensus 2022 (Leerstand/Eigentümerquote/Ø-Miete) - GRATIS, offline.
# Werte je Kreis in backend/data/zensus2022_kreise.csv eintragen (siehe backend/data/README.md).
# Optionaler abweichender Dateipfad:
# ZENSUS_FILE=/opt/dealpilot/backend/data/zensus2022_kreise.csv


# --- GeoMap Kostenbremsen ---
# Mehrfachabruf zur Glaettung (Default 1). Nur hochsetzen, falls die API bei identischer Abfrage schwankt.
GEOMAP_SAMPLES=1
# Max. Stuetzpunkte der Preis-/Miethistorie (Default 5). Start+Ende bleiben, CAGR unveraendert.
GEOMAP_HISTORY_MAX_POINTS=5
# Miethistorie zusaetzlich holen (verdoppelt Historie-Calls). false = nur aktuelle Miete + Kaufhistorie.
GEOMAP_HISTORY_RENT=true
