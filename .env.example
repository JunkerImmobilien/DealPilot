# ════════════════════════════════════════════════════════
# DealPilot — .env.example (Template)
# ════════════════════════════════════════════════════════
# Kopiere zu .env und fülle die Werte aus:
#   cp .env.example .env
#   nano .env

# ──── Domain ──────────────────────────────────────────
DOMAIN=dealpilot.junker-immobilien.io
FRONTEND_BASE_URL=https://dealpilot.junker-immobilien.io
ACME_EMAIL=info@junker-immobilien.io

# ──── Database ────────────────────────────────────────
DB_PASSWORD=CHANGE-ME-MIN-32-CHARS-STARK
DATABASE_SSL=false
DB_SSL=false
PGSSLMODE=disable

# ──── JWT / Auth ──────────────────────────────────────
JWT_SECRET=CHANGE-ME-mit-openssl-rand-hex-64
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
TOTP_ISSUER=DealPilot

# ──── Admin-Account beim ersten Start ─────────────────
ADMIN_EMAIL=info@junker-immobilien.io
ADMIN_NAME=Marcel Junker
ADMIN_PASSWORD=CHANGE-ME

# ──── Stripe ──────────────────────────────────────────
# Staging: Test-Keys (sk_test_xxx, pk_test_xxx)
# Production: Live-Keys (sk_live_xxx, pk_live_xxx)
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ──── OpenAI ──────────────────────────────────────────
OPENAI_API_KEY=sk-xxx
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# ──── Mail (alfahosting SMTP) ─────────────────────────
BETA_SMTP_HOST=host160.alfahosting-server.de
BETA_SMTP_PORT=465
BETA_SMTP_SECURE=true
BETA_SMTP_USER=info@junker-immobilien.io
BETA_SMTP_PASS=CHANGE-ME
BETA_MAIL_FROM="DealPilot <info@junker-immobilien.io>"
BETA_MAIL_TO=info@junker-immobilien.io
FEEDBACK_MAIL_TO=info@junker-immobilien.io
SUPPORT_MAIL_TO=info@junker-immobilien.io

# ──── Deal-Action Mail-Empfänger ──────────────────────
DEAL_ACTION_ALLOWED_RECIPIENTS=*
DEAL_ACTION_FALLBACK=info@junker-immobilien.io

# ──── Nextcloud Datenraum (optional) ──────────────────
NEXTCLOUD_BASE_URL=
NEXTCLOUD_USERNAME=
NEXTCLOUD_APP_PASSWORD=
NEXTCLOUD_BASE_FOLDER=DealPilot-Datenraum
NEXTCLOUD_SHARE_EXPIRES_DAYS=30

# ──── Misc ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
SEED_DEMO_DATA=false
SEND_CONFIRMATION_EMAILS=true
